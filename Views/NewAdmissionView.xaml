<UserControl x:Class="WpfAppSchoolDataBase.Views.NewAdmissionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppSchoolDataBase.Views"
             xmlns:vm="clr-namespace:WpfAppSchoolDataBase.ViewModels"
             xmlns:h="clr-namespace:WpfAppSchoolDataBase.Helper"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="700">
    <UserControl.Resources>
        <h:HorizontalAlignmentToTextAlignmentConverter x:Key="HorizontalAlignmentToTextAlignmentConverter"/>
        <h:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#1E293B" FontSize="13" Margin="2,0,0,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Adaptive Watermark Alignment Style Mapping Block Template -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <TextBlock x:Name="placeholderText" Text="{Binding Path=(h:WatermarkService.Watermark), RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="#9CA3AF" Margin="10,6,10,0" IsHitTestVisible="False" Visibility="Collapsed"
                                       HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                       TextAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource HorizontalAlignmentToTextAlignmentConverter}}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,15,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Full-Size Branded Banner Header -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Low-Profile Form Sheet Card -->
        </Grid.RowDefinitions>

        <!-- OFFICIAL FULL-SIZE ACADEMIC HEADER BANNER -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="25" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="5,0,25,0" VerticalAlignment="Center">
                    <Ellipse Width="100" Height="100" Fill="White" Panel.ZIndex="1"/>
                    <Ellipse Width="100" Height="100" Stroke="#60A5FA" StrokeThickness="2" Panel.ZIndex="2"/>
                    <Ellipse Width="94" Height="94" Panel.ZIndex="3" RenderOptions.BitmapScalingMode="HighQuality">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/WpfAppSchoolDataBase;component/Images/sps_logo.png" Stretch="Uniform"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SYED PUBLIC SCHOOL" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Course Registration Dossier" Foreground="#60A5FA" FontSize="17" FontWeight="SemiBold" Margin="0,2,0,2"/>
                    <TextBlock Text="{Binding LiveCalendarDate}" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOW-PROFILE DATA ENTRY SHEET -->
        <!-- Repair Chunk R1: Low-Profile Scroll Container & Group 1 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>

                    <!-- GROUP 1: PERSONAL & CORE IDENTIFICATION -->
                    <GroupBox Header="Personal &amp; Contact Details">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <!-- Full Legal Name -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Gender Radio Buttons -->
                                <ColumnDefinition Width="1.8*"/>
                                <!-- Date Picker (DOB) -->
                                <ColumnDefinition Width="2.5*"/>
                                <!-- Email Address -->
                                <ColumnDefinition Width="2*"/>
                                <!-- Phone Number -->
                            </Grid.ColumnDefinitions>

                            <!-- Full Name text field -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Label Content="Full Legal Name:"/>
                                <TextBox Text="{Binding StudentRecord.FullName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Ali Khan" PreviewTextInput="AlphabeticTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>

                            <!-- Gender Radio selection -->
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <Label Content="Gender:"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <RadioButton Content="Male" IsChecked="{Binding IsMale}" Margin="0,0,12,0" FontWeight="Medium"/>
                                    <RadioButton Content="Female" IsChecked="{Binding IsFemale}" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Date of Birth Selection DatePicker -->
                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <Label Content="Date Of Birth:"/>
                                <DatePicker Padding="2" SelectedDate="{Binding StudentRecord.DateOfBirth, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- Email Address input field -->
                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <Label Content="Email Address:"/>
                                <TextBox Text="{Binding StudentRecord.Email, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="username@domain.com" PreviewTextInput="EmailTextBox_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Phone Number input field -->
                            <StackPanel Grid.Column="4">
                                <Label Content="Phone Number:"/>
                                <TextBox Text="{Binding StudentRecord.PhoneNum, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. +923001234567" PreviewTextInput="PhoneTextBox_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                    <!-- Repair Chunk R2: Group 2, Group 3 & Base Toolbar -->
                    <!-- GROUP 2: RESIDENTIAL MAILING ADDRESS -->
                    <GroupBox Header="Residential Mailing Address">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <!-- Street Address -->
                                <ColumnDefinition Width="2*"/>
                                <!-- City Location -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- State / Province -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Right-Aligned Postal Code -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Label Content="Street Address:"/>
                                <TextBox Text="{Binding StudentRecord.StreetAddress, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="House No. 12, Street 3" PreviewTextInput="AlphanumericTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <Label Content="City Location:"/>
                                <TextBox Text="{Binding StudentRecord.City, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Peshawar" PreviewTextInput="AlphabeticTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <Label Content="State/Province:"/>
                                <TextBox Text="{Binding StudentRecord.StateProvince, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. KPK" PreviewTextInput="AlphabeticTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <Label Content="Postal Code:"/>
                                <TextBox Text="{Binding StudentRecord.PostalCode, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="23200" MaxLength="5" HorizontalContentAlignment="Right" PreviewTextInput="IntegerTextBox_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- GROUP 3: ACADEMIC HISTORY & INTENDED ENROLLMENT MAJOR -->
                    <GroupBox Header="Academic History &amp; Intended Enrollment Major">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3.5*"/>
                                <!-- Previous Institution Name -->
                                <ColumnDefinition Width="1.2*"/>
                                <!-- Right-Aligned Passing Year -->
                                <ColumnDefinition Width="1*"/>
                                <!-- Right-Aligned Masked GPA Box -->
                                <ColumnDefinition Width="4.3*"/>
                                <!-- Selection Major ComboBox -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Label Content="Previous Institution Name:"/>
                                <TextBox Text="{Binding StudentRecord.PrevSchoolName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Syed Public High School" PreviewTextInput="AlphanumericTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <Label Content="Passing Year:"/>
                                <TextBox Text="{Binding StudentRecord.GraduationYear, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="YYYY" MaxLength="4" HorizontalContentAlignment="Right" PreviewTextInput="IntegerTextBox_PreviewTextInput"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <Label Content="GPA:"/>
                                <TextBox Text="{Binding StudentRecord.GPA, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" h:WatermarkService.Watermark="0.00" HorizontalContentAlignment="Right" PreviewTextInput="GPATextBox_PreviewTextInput"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <Label Content="Assigned Academic Major Selection:" Foreground="#2563EB"/>
                                <ComboBox ItemsSource="{Binding AvailableCourses}" Padding="5" Height="28" DisplayMemberPath="CourseName" SelectedValuePath="CourseID" SelectedValue="{Binding StudentRecord.CourseID, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- BOTTOM ADMINISTRATIVE WORKFLOW TOOLBAR STRIP -->
                    <Grid Margin="2,4,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Dossier Pipeline Status: " Foreground="#6B7280" FontWeight="Medium" VerticalAlignment="Center"/>
                            <Border Background="#EFF6FF" CornerRadius="4" Padding="8,4" Margin="5,0,0,0">
                                <TextBlock Text="{Binding StudentRecord.ApplicationStatus}" Foreground="#2563EB" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1" Content="💾 Save &amp; Finalize Admission Profile" 
                                Command="{Binding SaveAndExitCommand}" 
                                Background="#10B981" Foreground="White" 
                                Padding="22,10" FontSize="13" FontWeight="Bold" 
                                BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
