<UserControl x:Class="WpfAppSchoolDataBase.Views.NewAdmissionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WpfAppSchoolDataBase.ViewModels"
             xmlns:h="clr-namespace:WpfAppSchoolDataBase.Helper"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- 1. Your Existing Date Converter from Step 7.2 -->
        <h:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter"/>

        <!-- 2. PASTE THE NEW ALIGNMENT CONVERTER RIGHT HERE: -->
        <h:HorizontalAlignmentToTextAlignmentConverter x:Key="HorizontalAlignmentToTextAlignmentConverter"/>

        <!-- Clean Label Layout Rule -->
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Clean Professional GroupBox Styling Rule -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#1E293B" FontSize="14" Margin="5,0,5,5"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Attached Property Placeholder Style configuration for text fields -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <!-- UPGRADED: Dynamic alignment binding matches the text box direction automatically -->
                            <TextBlock x:Name="placeholderText" Text="{Binding Path=(h:WatermarkService.Watermark), 
                                RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="#9CA3AF" Margin="10,6,10,0" 
                                       IsHitTestVisible="False" Visibility="Collapsed"
                                       HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                       TextAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource HorizontalAlignmentToTextAlignmentConverter}}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Official Branded Academic Header -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Grouped Dossier Form Frame Workspace -->
        </Grid.RowDefinitions>

        <!-- OFFICIAL RE-DESIGNED INSTITUTIONAL BANNER FRAME -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo Crest Shield -->
                    <ColumnDefinition Width="*"/>
                    <!-- School Branding Text Block -->
                </Grid.ColumnDefinitions>

                <!-- High-Quality White-Backed Round Crest Logo Shield -->
                <Grid Grid.Column="0" Margin="5,0,20,0" VerticalAlignment="Center">
                    <Ellipse Width="85" Height="85" Fill="White" Panel.ZIndex="1"/>
                    <Ellipse Width="85" Height="85" Stroke="#60A5FA" StrokeThickness="2" Panel.ZIndex="2"/>
                    <Ellipse Width="80" Height="80" Panel.ZIndex="3" RenderOptions.BitmapScalingMode="HighQuality">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/WpfAppSchoolDataBase;component/Images/sps_logo.png" Stretch="Uniform"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <!-- Layered Typography Layout -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SYED PUBLIC SCHOOL" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Admission Form" Foreground="#60A5FA" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,2"/>
                    <TextBlock Text="{Binding CurrentAcademicYear}" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Local Responsive Scroll Workspace for Laptop viewports -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="25">
                <StackPanel>

                    <!-- REGION 1: PERSONAL INFORMATION -->
                    <GroupBox Header="Personal Info">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Input Labels -->
                                <ColumnDefinition Width="*"/>
                                <!-- Proportional Fields -->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Full Name (Takes up wide horizontal room naturally) -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Full Legal Name:" Target="{Binding ElementName=TxtFullName}"/>
                            <TextBox x:Name="TxtFullName" Grid.Row="0" Grid.Column="1" MaxWidth="500" 
                                     HorizontalAlignment="Left" Width="400"
                                     Text="{Binding StudentRecord.FullName, UpdateSourceTrigger=PropertyChanged}" 
                                     h:WatermarkService.Watermark="First Middle Last (e.g. Johnathan Doe)"
                                     PreviewTextInput="AlphabeticTextBox_PreviewTextInput"
                                     LostFocus="TextClean_LostFocus"/>

                            <!-- Gender Selection via RadioButtons instead of generic typing -->
                            <Label Grid.Row="1" Grid.Column="0" Content="Gender Selection:"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,10">
                                <RadioButton Content="Male" IsChecked="{Binding IsMale}" Margin="0,0,20,0" FontWeight="Medium" Foreground="#374151"/>
                                <RadioButton Content="Female" IsChecked="{Binding IsFemale}" FontWeight="Medium" Foreground="#374151"/>
                            </StackPanel>

                            <!-- Date of Birth Selection utilizing a modern secure DatePicker control -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Date Of Birth:"/>
                            <DatePicker Grid.Row="2" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="3"
                                        SelectedDate="{Binding StudentRecord.DateOfBirth, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </GroupBox>
                    <!-- REGION 2: CONTACT & MAILING INFORMATION -->
                    <GroupBox Header="Contact Info">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <!-- Label alignment spacer -->
                                <ColumnDefinition Width="2*"/>
                                <!-- Main box input text box layout -->
                                <ColumnDefinition Width="80"/>
                                <!-- Secondary layout fields code -->
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Email Address:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" MaxWidth="500" HorizontalAlignment="Left" Width="400"
         Text="{Binding StudentRecord.Email, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="username@domain.com"
         PreviewTextInput="EmailTextBox_PreviewTextInput"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Phone Number:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left"
         Text="{Binding StudentRecord.PhoneNum, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. +1-555-019-9222"
         PreviewTextInput="PhoneTextBox_PreviewTextInput"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Street Address:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding StudentRecord.StreetAddress, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="Apartment, Suite, Unit, Street Number and Name"
         PreviewTextInput="AlphanumericTextBox_PreviewTextInput"
         LostFocus="TextClean_LostFocus"/>
                        </Grid>
                    </GroupBox>
                    <!-- REGION 3: GEOGRAPHIC & MAILING TAILS -->
                    <GroupBox Header="Mailing Coordinates">
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,15,0">
                                <Label Content="City:"/>
                                <TextBox Text="{Binding StudentRecord.City, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Seattle"
                 PreviewTextInput="AlphabeticTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0">
                                <Label Content="State / Province:"/>
                                <TextBox Text="{Binding StudentRecord.StateProvince, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. WA"
                 PreviewTextInput="AlphabeticTextBox_PreviewTextInput" LostFocus="TextClean_LostFocus"/>
                            </StackPanel>
                            <StackPanel>
                                <Label Content="Postal / ZIP Code:"/>
                                <TextBox Text="{Binding StudentRecord.PostalCode, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. 98101"
                 HorizontalContentAlignment="Right" PreviewTextInput="IntegerTextBox_PreviewTextInput"/>
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>

                    <!-- REGION 4: PREVIOUS ACADEMIC RECORD -->
                    <GroupBox Header="Previous Academic Record">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Previous School Name:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StudentRecord.PrevSchoolName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. West High School"
         PreviewTextInput="AlphanumericTextBox_PreviewTextInput"
         LostFocus="TextClean_LostFocus"/>
                            <Label Grid.Row="0" Grid.Column="2" Content="Passing Year:" Margin="15,0,0,0"/>
                            <!-- Upgraded: Right-aligned and keystroke filtered -->
                            <TextBox Grid.Row="0" Grid.Column="3" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding StudentRecord.GraduationYear, UpdateSourceTrigger=PropertyChanged}" 
                                     h:WatermarkService.Watermark="YYYY"
                                     HorizontalContentAlignment="Right"
                                     PreviewTextInput="IntegerTextBox_PreviewTextInput"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="Cumulative GPA:"/>
                            <!-- Cleared hardcoded values: Completely empty text binding with right-aligned format guides -->
                            <TextBox Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding StudentRecord.Gpa, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
                                     h:WatermarkService.Watermark="0.00"
                                     HorizontalContentAlignment="Right"
                                     PreviewTextInput="IntegerTextBox_PreviewTextInput"/>
                        </Grid>
                    </GroupBox>

                    <!-- REGION 5: INTENDED PROGRAM ALLOCATION -->
                    <GroupBox Header="Program Enrollment Allocation">
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                            <Label Content="Select Academic Major Program:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <ComboBox ItemsSource="{Binding AvailableCourses}" Width="350" Padding="6" VerticalAlignment="Center"
                                      DisplayMemberPath="CourseName" SelectedValuePath="CourseID" 
                                      SelectedValue="{Binding StudentRecord.CourseID, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </GroupBox>
                    <!-- ADMINISTRATIVE REGISTRATION WORKFLOW META -->
                    <Grid Margin="5,10,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="File Status Monitor: " Foreground="#6B7280" FontWeight="Medium" VerticalAlignment="Center"/>
                            <Border Background="#EFF6FF" CornerRadius="4" Padding="8,4" Margin="5,0,0,0">
                                <TextBlock Text="{Binding StudentRecord.ApplicationStatus}" Foreground="#2563EB" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Proportional Standalone Action Execution System Button -->
                        <Button Grid.Column="1" Content="💾 Save &amp; Finalize Admission Profile" 
                                Command="{Binding SaveAndExitCommand}" 
                                Background="#10B981" Foreground="White" 
                                Padding="20,12" FontSize="14" FontWeight="Bold" 
                                BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>