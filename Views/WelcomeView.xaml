<UserControl x:Class="WpfAppSchoolDataBase.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppSchoolDataBase.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="950">

    <!-- Pure XAML Graphic Animation Engine -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContentGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="MainContentGrid" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Welcome Hero Banner -->
            <RowDefinition Height="*"/>
            <!-- Quick Links Grid Core Workspace -->
        </Grid.RowDefinitions>

        <!-- Top Hero Box Profile Welcome Grid Section -->
        <!-- Top Hero Box Profile Welcome Grid Section -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Margin="25,25,25,15" Padding="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Text Intro Meta -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Graphic Shield Logo Slot -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Welcome to School Enterprise ERP" Foreground="#60A5FA" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="Syed Public School" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,10"/>
                    <TextBlock Text="Continuous excellence in academic monitoring, secure records management, and real-time student registration pipelines. Navigate using the sidebar menu options matrix to begin your management workflow." 
                               Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left" LineHeight="20"/>
                </StackPanel>

                <!-- Upgraded: High-Visibility Scaled Circular Logo Framework Layering Matrix -->
                <Grid Grid.Column="1" Margin="25,0,10,0" VerticalAlignment="Center">
                    <!-- Layer 1: Solid White Circular Shield Backdrop (Ensures high text readability) -->
                    <Ellipse Width="135" Height="135" Fill="White" Panel.ZIndex="1"/>

                    <!-- Layer 2: Outer Accent Border Ring matching the corporate ERP scheme -->
                    <Ellipse Width="135" Height="135" Stroke="#60A5FA" StrokeThickness="2.5" Panel.ZIndex="2"/>

                    <!-- Layer 3: High-Quality Render-Sampled Transparent School Logo Graphic Asset -->
                    <Ellipse Width="128" Height="128" Panel.ZIndex="3"
                             RenderOptions.BitmapScalingMode="HighQuality">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/WpfAppSchoolDataBase;component/Images/sps_logo.png" 
                                        Stretch="Uniform"
                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

            </Grid>
        </Border>



        <!-- Operational Matrix Cards Row Segment Grid 1 Area -->
        <Grid Grid.Row="1" Margin="25,10,25,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- CARD 1: ADMISSIONS BOARD OVERVIEW -->
            <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,10,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="📝 New Student Registration" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6"/>
                    <TextBlock Text="Process freshman applications, format data inputs cleanly with real-time watermark helpers, and run defensive validation check triggers." 
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- CARD 2: COURSE MASTER CATALOG -->
            <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10,0,0,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="📚 Course Master Log" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6"/>
                    <TextBlock Text="Configure available university programs, assign credential values, and map core tracking relationships to relational database engine tiers." 
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- CARD 3: ADVANCED FILTERING MATRIX SEARCH SHEET -->
            <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,10,10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔍 Dynamic Query Search" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6"/>
                    <TextBlock Text="Filter records globally using multi-field constraints like admission years or course codes, unlocking isolated modify or drop action updates." 
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- CARD 4: ACADEMIC REPORTS METRICS BOARD -->
            <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10,10,0,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="📊 Enterprise Analytics" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6"/>
                    <TextBlock Text="Aggregate system metrics to compile student population parameters, verify program allocations, and export unified reporting metrics boards." 
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>