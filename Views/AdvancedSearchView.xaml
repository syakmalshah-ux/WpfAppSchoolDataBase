<UserControl x:Class="WpfAppSchoolDataBase.Views.AdvancedSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppSchoolDataBase.Views"
             xmlns:conv="clr-namespace:WpfAppSchoolDataBase.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="850">

    <UserControl.Resources>
        <!-- Unique Local Converter Keys -->
        <BooleanToVisibilityConverter x:Key="LocalBoolToVisConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:DateOnlyToStringConverter x:Key="DateOnlyToStringConverter" />

        <!-- Style for Action Trays -->
        <Style x:Key="InverseBooleanToVisibilityConverter" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFormLocked, FallbackValue=False}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- NewAdmissionView Control Styling Templates -->
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#1E293B" FontSize="13" Margin="2,0,0,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,15,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Full-Size Branded Academic Banner Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Search Execution Bar & Ticker Message -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Form Sheet Card -->
        </Grid.RowDefinitions>

        <!-- ROW 0: OFFICIAL FULL-SIZE ACADEMIC HEADER BANNER -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="25" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="5,0,25,0" VerticalAlignment="Center">
                    <Ellipse Width="100" Height="100" Fill="White" Panel.ZIndex="1"/>
                    <Ellipse Width="100" Height="100" Stroke="#60A5FA" StrokeThickness="2" Panel.ZIndex="2"/>
                    <Ellipse Width="94" Height="94" Panel.ZIndex="3" RenderOptions.BitmapScalingMode="HighQuality">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/WpfAppSchoolDataBase;component/Images/sps_logo.png" Stretch="Uniform"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SYED PUBLIC SCHOOL" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Advanced Student Search &amp; Management" Foreground="#60A5FA" FontSize="17" FontWeight="SemiBold" Margin="0,2,0,2"/>
                    <TextBlock Text="{Binding LiveCalendarDate}" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: SEARCH BAR AND TICKER MESSAGING -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Border Background="#F1F5F9" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <RadioButton Content="Search by ID" IsChecked="{Binding IsSearchById, Mode=TwoWay}" Foreground="#1E293B" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <RadioButton Content="Search by Name" IsChecked="{Binding IsSearchByName, Mode=TwoWay}" Foreground="#1E293B" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBox Grid.Column="1" Text="{Binding SearchIdInput, UpdateSourceTrigger=PropertyChanged}" MaxLength="8" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Visibility="{Binding IsSearchById, Converter={StaticResource LocalBoolToVisConverter}}"/>

                    <TextBox Grid.Column="3" Text="{Binding SearchNameInput, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Visibility="{Binding IsSearchByName, Converter={StaticResource LocalBoolToVisConverter}}"/>

                    <Button Grid.Column="4" Command="{Binding ExecuteSearchCommand}" Content="🔍 Execute Matrix Search" Width="170" Height="28" Background="#1E293B" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="15,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <TextBlock Text="{Binding TickerMessage}" Foreground="#1E293B" FontSize="11" FontWeight="Bold" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- ROW 2: GROUPED FORM SHEET CARD SHEET CONTAINER -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>

                    <!-- GROUP 1: PERSONAL & CONTACT DETAILS -->
                    <GroupBox Header="Personal &amp; Contact Details">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <!-- Student ID -->
                                <ColumnDefinition Width="3*"/>
                                <!-- Full Name -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Gender -->
                                <ColumnDefinition Width="2.5*"/>
                                <!-- Email Address -->
                                <ColumnDefinition Width="2*"/>
                                <!-- Phone Number -->
                            </Grid.ColumnDefinitions>

                            <!-- Student ID -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Label Content="Student ID:"/>
                                <TextBox Text="{Binding StudentRecord.StudentID}" IsReadOnly="True" Background="#E2E8F0" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                            </StackPanel>

                            <!-- Full Legal Name -->
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <Label Content="Full Legal Name:"/>
                                <TextBox Text="{Binding StudentRecord.FullName}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Gender Radio selection -->
                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <Label Content="Gender:"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <RadioButton Content="Male" GroupName="GenderGroup" IsChecked="{Binding IsGenderMale, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" Margin="0,0,12,0" FontWeight="Medium"/>
                                    <RadioButton Content="Female" GroupName="GenderGroup" IsChecked="{Binding IsGenderFemale, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Email Address -->
                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <Label Content="Email Address:"/>
                                <TextBox Text="{Binding StudentRecord.Email}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Phone Number -->
                            <StackPanel Grid.Column="4">
                                <Label Content="Phone Number:"/>
                                <TextBox Text="{Binding StudentRecord.PhoneNum}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- GROUP 2: RESIDENTIAL MAILING ADDRESS -->
                    <GroupBox Header="Residential Mailing Address">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <!-- Street Address -->
                                <ColumnDefinition Width="2*"/>
                                <!-- City Location -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- State / Province -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Postal Code -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Label Content="Street Address:"/>
                                <TextBox Text="{Binding StudentRecord.StreetAddress}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <Label Content="City Location:"/>
                                <TextBox Text="{Binding StudentRecord.City}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <Label Content="State/Province:"/>
                                <TextBox Text="{Binding StudentRecord.StateProvince}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <Label Content="Postal Code:"/>
                                <TextBox Text="{Binding StudentRecord.PostalCode}" IsReadOnly="{Binding IsFormLocked}" MaxLength="5" Height="28" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- GROUP 3: ACADEMIC HISTORY, DATES & ENROLLMENT -->
                    <GroupBox Header="Academic History, Dates &amp; Status">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <!-- Previous Institution Name -->
                                <ColumnDefinition Width="1.2*"/>
                                <!-- Passing Year -->
                                <ColumnDefinition Width="1*"/>
                                <!-- GPA -->
                                <ColumnDefinition Width="3.5*"/>
                                <!-- Enrolled Course -->
                                <ColumnDefinition Width="1.8*"/>
                                <!-- Date Of Birth -->
                                <ColumnDefinition Width="1.8*"/>
                                <!-- Admission Date -->
                                <ColumnDefinition Width="2*"/>
                                <!-- Application Status -->
                            </Grid.ColumnDefinitions>

                            <!-- Previous School Name -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <Label Content="Previous Institution:"/>
                                <TextBox Text="{Binding StudentRecord.PrevSchoolName}" IsReadOnly="{Binding IsFormLocked}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Passing Year -->
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <Label Content="Passing Year:"/>
                                <TextBox Text="{Binding StudentRecord.GraduationYear}" IsReadOnly="{Binding IsFormLocked}" MaxLength="4" Height="28" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- GPA -->
                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <Label Content="GPA:"/>
                                <TextBox Text="{Binding StudentRecord.GPA}" IsReadOnly="{Binding IsFormLocked}" Height="28" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Enrolled Course -->
                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <Label Content="Enrolled Course Selection:" Foreground="#2563EB"/>
                                <ComboBox ItemsSource="{Binding AvailableCourses}" SelectedValue="{Binding StudentRecord.CourseID}" SelectedValuePath="CourseID" DisplayMemberPath="CourseName" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" Height="28" Padding="5,3"/>
                            </StackPanel>

                            <!-- Date of Birth -->
                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <Label Content="Date Of Birth:"/>
                                <DatePicker SelectedDate="{Binding StudentRecord.DateOfBirthDateTime, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Admission Date -->
                            <StackPanel Grid.Column="5" Margin="0,0,10,0">
                                <Label Content="Admission Date:"/>
                                <DatePicker SelectedDate="{Binding StudentRecord.AdmissionDateDateTime, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Application Status -->
                            <StackPanel Grid.Column="6">
                                <Label Content="App Status:"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <RadioButton Content="Pending" GroupName="StatusGroup" IsChecked="{Binding IsStatusPending, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" Margin="0,0,8,0" FontWeight="Medium"/>
                                    <RadioButton Content="Approved" GroupName="StatusGroup" IsChecked="{Binding IsStatusApproved, Mode=TwoWay}" IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBooleanConverter}}" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- ACTION TOOLBAR STRIP -->
                    <Grid Margin="2,8,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Save / Cancel tray (Visible when IsFormLocked = False) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Style="{StaticResource InverseBooleanToVisibilityConverter}">
                            <Button Command="{Binding UpdateChangesCommand}" Content="💾 Update Changes" Width="150" Height="34" Background="#16A34A" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                            <Button Command="{Binding CancelEditCommand}" Content="❌ Cancel Edit" Width="130" Height="34" Background="#64748B" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Edit / Delete tray (Visible when IsFormLocked = True) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsFormLocked, Converter={StaticResource LocalBoolToVisConverter}}">
                            <Button Command="{Binding ChangeToEditStateCommand}" Content="📝 Edit Record" Width="140" Height="34" Background="#2563EB" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                            <Button Command="{Binding ExecuteDeleteCommand}" Content="🗑️ Delete Record" Width="140" Height="34" Background="#DC2626" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>