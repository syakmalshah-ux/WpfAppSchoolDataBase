<UserControl x:Class="WpfAppSchoolDataBase.Views.CourseEntriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppSchoolDataBase.ViewModels"
             xmlns:vm="clr-namespace:WpfAppSchoolDataBase.ViewModels"
             xmlns:h="clr-namespace:WpfAppSchoolDataBase.Helper"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:CourseEntriesViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <h:HorizontalAlignmentToTextAlignmentConverter x:Key="HorizontalAlignmentToTextAlignmentConverter"/>

        <!-- Clean Compact Labels for Course Form -->
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Compact Form GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#1E293B" FontSize="13" Margin="2,0,0,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Adaptive Watermark Styling Block Template -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <TextBlock x:Name="placeholderText" Text="{Binding Path=(h:WatermarkService.Watermark), RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="#9CA3AF" Margin="10,6,10,0" IsHitTestVisible="False" Visibility="Collapsed"
                                       HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                       TextAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource HorizontalAlignmentToTextAlignmentConverter}}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <!-- Chunk F2: School Crest Header Banner & Lean Horizontal Data Entry Grid -->
    <Grid Margin="20,15,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Full-Size Branded Header Banner -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Low-Profile Form Sheet Card -->
        </Grid.RowDefinitions>

        <!-- OFFICIAL FULL-SIZE ACADEMIC HEADER BANNER -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="25" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- High-Visibility White-Backed Logo Shield Frame -->
                <Grid Grid.Column="0" Margin="5,0,25,0" VerticalAlignment="Center">
                    <Ellipse Width="100" Height="100" Fill="White" Panel.ZIndex="1"/>
                    <Ellipse Width="100" Height="100" Stroke="#60A5FA" StrokeThickness="2" Panel.ZIndex="2"/>
                    <Ellipse Width="94" Height="94" Panel.ZIndex="3" RenderOptions.BitmapScalingMode="HighQuality">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/WpfAppSchoolDataBase;component/Images/sps_logo.png" Stretch="Uniform"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SYED PUBLIC SCHOOL" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Course Registration Dossier" Foreground="#60A5FA" FontSize="17" FontWeight="SemiBold" Margin="0,2,0,2"/>
                    <TextBlock Text="{Binding LiveCalendarDate}" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOW-PROFILE DATA ENTRY SHEET -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                <StackPanel>

                    <!-- COMPACT LEAN SPECIFICATION REGION FOR THE 4 SCHEMA COLUMNS -->
                    <GroupBox Header="Course Specification Parameters">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <!-- 1. Course Code Identifier -->
                                <ColumnDefinition Width="4*"/>
                                <!-- 2. Course Name Title String -->
                                <ColumnDefinition Width="3*"/>
                                <!-- 3. Department Combo Dropdown -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- 4. Credits Combo Dropdown -->
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Course Code Input Mask -->
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <Label Content="Course Code:"/>
                                <TextBox Text="{Binding CourseCode, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. CS-101" MaxLength="6" CharacterCasing="Upper" PreviewTextInput="CourseCode_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Column 2: Flat Course Name Input -->
                            <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                <Label Content="Course Title:"/>
                                <TextBox Text="{Binding CourseName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Object Oriented Programming" PreviewTextInput="AlphaText_PreviewTextInput" LostFocus="StringClean_LostFocus"/>
                            </StackPanel>

                            <!-- Column 3: Department Selection over typing -->
                            <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                <Label Content="Department Group:" Foreground="#2563EB"/>
                                <ComboBox ItemsSource="{Binding DepartmentCatalog}" SelectedItem="{Binding SelectedDepartment}" Height="28" Padding="5"/>
                            </StackPanel>

                            <!-- Column 4: Credit Value Selection over typing -->
                            <StackPanel Grid.Column="3">
                                <Label Content="Credits Count:" Foreground="#2563EB"/>
                                <ComboBox ItemsSource="{Binding CreditValueOptions}" SelectedItem="{Binding SelectedCredits}" Height="28" Padding="5"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                    <!-- Chunk F3: Target Status Strip & Green Database Commit Button -->
                    <Grid Margin="2,5,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Read-Only System Badge Tracker -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="System Target State: " Foreground="#6B7280" FontWeight="Medium" VerticalAlignment="Center"/>
                            <Border Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="5,0,0,0">
                                <TextBlock Text="Active Catalog Struct" Foreground="#374151" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <!-- Non-Scrolling Execution Save Button -->
                        <Button Grid.Column="1" Content="💾 Save &amp; Log Program Course" 
                                Command="{Binding SaveCourseToCatalogCommand}" 
                                Background="#10B981" Foreground="White" 
                                Padding="25,12" FontSize="13" FontWeight="Bold" 
                                BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
