<!-- 
    The Opening Window Definition and Namespaces: 
    This chunk forms the outer shell of your user interface and configures 
    the connection paths for your ViewModels and the Attached Property Placeholder helper.
    -->

<Window x:Class="WpfAppSchoolDataBase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppSchoolDataBase"
        xmlns:vm="clr-namespace:WpfAppSchoolDataBase.ViewModels"
        xmlns:v="clr-namespace:WpfAppSchoolDataBase.Views"
        mc:Ignorable="d"
        Title="SYED Public School ERP System"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        WindowState="Maximized">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <!-- CRUCIAL DICTIONARY MAP: Links business views to visual user panels dynamically -->
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
            <v:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NewAdmissionViewModel}">
            <v:NewAdmissionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CourseEntriesViewModel}">
            <v:CourseEntriesView />
        </DataTemplate>
        
        <!-- Standard Button Visual Styling Scheme Rules -->
        <Style x:Key="SidebarMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Blueprint Grid: 2 rows, 2 columns. Column 0 Spans 2 Rows for the Left Menu UI -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <!-- Column 0: Fixed Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Column 1: Workspace Panel Display Viewport Cell -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Top Status Title Bar Frame (Optional) -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Workspace View Frame Core -->
        </Grid.RowDefinitions>

        <!-- Left Menu Sidebar Component Pane (Spans over both vertical rows) -->
        <Grid Background="#1E293B" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
            <StackPanel Margin="15,30,15,0">
                <TextBlock Text="School ERP System" Foreground="White" FontSize="20" FontWeight="Bold" Margin="10,0,0,35"/>

                <!-- Menu Command Execution Links -->
                <Button Content="🏠 Dashboard Home" Command="{Binding NavigateToWelcomeCommand}" Style="{StaticResource SidebarMenuButtonStyle}"/>
                <Button Content="📝 New Admission" Command="{Binding NavigateToNewAdmissionCommand}" Style="{StaticResource SidebarMenuButtonStyle}"/>
                <Button Content="📚 Course Catalog" Command="{Binding NavigateToCourseEntriesCommand}"  Style="{StaticResource SidebarMenuButtonStyle}"/>
                <Button Content="🔍 Student Search" Style="{StaticResource SidebarMenuButtonStyle}"/>
                <Button Content="📊 Academic Reports" Style="{StaticResource SidebarMenuButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Main Screen Workspace Content Viewport (Row 0 & 1, Column 1) -->
        <!-- ContentControl dynamically renders whichever view model class layer is currently active -->
        <ContentControl Content="{Binding CurrentView}" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</Window>