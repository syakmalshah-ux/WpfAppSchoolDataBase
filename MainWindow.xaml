<!-- 
    The Opening Window Definition and Namespaces: 
    This chunk forms the outer shell of your user interface and configures 
    the connection paths for your ViewModels and the Attached Property Placeholder helper.
    -->
    
    <Window x:Class="WpfAppSchoolDataBase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppSchoolDataBase"
        xmlns:vm="clr-namespace:WpfAppSchoolDataBase.ViewModels"
        xmlns:h="clr-namespace:WpfAppSchoolDataBase.Helper"
        mc:Ignorable="d"
        Title="School Administration Dashboard" Height="700" Width="1150"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <!-- The Resources Section (Styles and Placeholders) 
    This chunk defines how your text boxes behave. 
    It houses the custom template that displays formatting hints 
    when a user has not typed anything into an input field.
    -->
    <Window.Resources>
        <!-- Blue Theme Header Design for the Data Table -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Microsoft Learn Template: Controls Floating/Fading Form Placeholders -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <!-- Watermark Layer Overlay Trigger -->
                            <TextBlock x:Name="placeholderText" Text="{Binding Path=(h:WatermarkService.Watermark), RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="#9CA3AF" Style="{x:Null}" Margin="10,5,0,0" IsHitTestVisible="False" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <!-- Outer Structure and Left Sidebar 
    This segment sets up the column/row layout grid partitions for the dashboard canvas and 
    draws the professional dark-colored menu column on the left side of the window.
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <!-- Left Menu Column -->
            <ColumnDefinition Width="*"/>
            <!-- Right Operations Board -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar Grid Background Frame -->
        <Grid Background="#1E293B" Grid.Column="0">
            <StackPanel Margin="20,30,20,0">
                <TextBlock Text="SchoolDB Admin" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,30"/>
                <Button Content="Admission Board" Background="#334155" Foreground="White" Padding="12" Margin="0,0,0,10" BorderThickness="0" HorizontalContentAlignment="Left" FontWeight="Medium"/>
            </StackPanel>
        </Grid>

        <!-- Right Main Workspace Header and Action Toolbar Strip 
        This component sets up the workspace area rows on the right and 
        populates the top with title descriptions alongside your Create Blank Record and 
        Delete Selected utility buttons.
        -->
        <!-- The following code generated a fixed view in which the bottom button were not visible.
        <Grid Grid.Column="1" Margin="25">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/> -->
        <!-- Title Description -->
        <!-- <RowDefinition Height="Auto"/> -->
        <!-- Toolbar Buttons -->
        <!-- <RowDefinition Height="1.5*"/> -->
        <!-- Data Matrix Table Grid -->
        <!-- <RowDefinition Height="2.5*"/> -->
        <!-- Profile Editing Form Sheet -->
        <!-- </Grid.RowDefinitions> -->
        
            <!-- Core Control Area -->
        <!-- Right Core Operations Content Workspace - Upgraded with ScrollBox Wrapper -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Grid.Column ="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Welcome Header Row -->
                    <RowDefinition Height="Auto"/>
                    <!-- CRUD Action Utility Strip Bar -->
                    <RowDefinition Height="300"/>
                    <!-- Fixed: Data Grid Matrix Board height -->
                    <RowDefinition Height="*"/>
                    <!-- Fixed: Dynamic Form fits content automatically -->
                </Grid.RowDefinitions>
                <!--
                Note: Changing row heights to 300 and Auto 
                stabilizes the content dimensions, preventing WPF from squishing your inputs or 
                rendering buttons out of bounds).
                -->
                <!-- Workspace Welcome Title Row 0 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Student Admissions Portal" FontSize="26" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Complete form textboxes using proper data formats before saving records." FontSize="13" Foreground="#6B7280" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Core Operations Toolbar Strip Row 1 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="+ Create Blank Application Record" Command="{Binding NewStudentCommand}" Background="#2563EB" Foreground="White" Padding="15,8" FontWeight="Medium" BorderThickness="0" Margin="0,0,10,0"/>
                <Button Content="🗑 Delete Selected" Command="{Binding DeleteStudentCommand}" Background="#DC2626" Foreground="White" Padding="15,8" FontWeight="Medium" BorderThickness="0"/>
            </StackPanel>

            <!-- The Table Matrix Viewer (DataGrid) 
            This chunk draws the tabular grid map in Row 2, 
            linking row selection variables directly to your data backend tracking arrays.
            -->
            <!-- Interactive DataGrid Matrix Row 2 -->
            <Grid Grid.Row="2" Margin="0,0,0,15">
                <DataGrid ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="White" BorderBrush="#E5E7EB" GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#E5E7EB" MaxHeight="300" HorizontalAlignment="Stretch" 
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <!-- Assigned explicit pixel widths to prevent columns from squeezing -->
                            <!-- Personal Profile Coordinates -->
                            <DataGridTextColumn Header="ID" Binding="{Binding StudentID}" Width="50"/>
                            <DataGridTextColumn Header="Full Applicant Name" Binding="{Binding FullName}" Width="160"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                            <DataGridTextColumn Header="Date of Birth" Binding="{Binding DateOfBirth}" Width="100"/>
                            <DataGridTextColumn Header="Electronic Email" Binding="{Binding Email}" Width="180"/>
                            <DataGridTextColumn Header="Phone Number" Binding="{Binding PhoneNum}" Width="120"/>

                            <!-- Physical Mailing Address Coordinates -->
                            <DataGridTextColumn Header="Street Address" Binding="{Binding StreetAddress}" Width="180"/>
                            <DataGridTextColumn Header="City" Binding="{Binding City}" Width="100"/>
                            <DataGridTextColumn Header="State / Prov" Binding="{Binding StateProvince}" Width="90"/>
                            <DataGridTextColumn Header="Postal Code" Binding="{Binding PostalCode}" Width="90"/>

                            <!-- Prior Academic History Coordinates -->
                            <DataGridTextColumn Header="Previous Institution" Binding="{Binding PrevSchoolName}" Width="160"/>
                            <DataGridTextColumn Header="GPA" Binding="{Binding Gpa}" Width="60"/>
                            <DataGridTextColumn Header="Grad Year" Binding="{Binding GraduationYear}" Width="80"/>

                            <!-- Registration Program Profile Coordinates -->
                            <DataGridTextColumn Header="Major ID" Binding="{Binding CourseID}" Width="80"/>
                            <DataGridTextColumn Header="Application Status" Binding="{Binding ApplicationStatus}" Width="120"/>

                        </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Profile Input Sheet Card — Form Column 1 (Personal Data) 
            This block constructs the beginning of your 
            profile property input editor panel card located at the bottom of your app screen inside Row 3, 
            providing form inputs for name, gender, birthdate, email, and phone.
            -->
            <!-- Profile Properties Card Panel Row 3 -->
            <Border Grid.Row="3" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Student Profile Form Properties Editor" Grid.Row="0" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PROFILE COLUMN 1: Personal Identification Fields -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Full Legal Name" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.FullName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Johnathan Doe"/>

                            <TextBlock Text="Gender" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.Gender, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="Male, Female, or Other"/>

                            <TextBlock Text="Date Of Birth" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.DateOfBirth, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="YYYY-MM-DD (e.g. 2005-04-12)"/>

                            <TextBlock Text="Primary Email Address" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.Email, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="name@example.com"/>

                            <TextBlock Text="Contact Phone Number" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.PhoneNum, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="555-0199 or +1-555-0199"/>
                        </StackPanel>

                        <!-- Profile Input Sheet Card — Form Column 2 (Address & Dropdown) 
                        This block builds the middle row section of your data management panel, 
                        housing your address text boxes and the Dynamic Course ComboBox Dropdown menu.
                        -->
                        <!-- PROFILE COLUMN 2: Mailing Address Information & Course Selection -->
                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="Street Address" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.StreetAddress, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. 123 Maple Avenue"/>

                            <TextBlock Text="City" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.City, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. Seattle"/>

                            <TextBlock Text="State / Province" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.StateProvince, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. WA"/>

                            <TextBlock Text="Postal / ZIP Code" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.PostalCode, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. 98101"/>

                            <!-- THE DYNAMIC COURSE COMBOBOX DROPDOWN CONTROL -->
                            <TextBlock Text="Assigned Academic Major" FontWeight="Medium" Margin="0,0,0,4" Foreground="#2563EB"/>
                            <ComboBox ItemsSource="{Binding Courses}" DisplayMemberPath="CourseName" SelectedValuePath="CourseID" 
                                      SelectedValue="{Binding SelectedStudent.CourseID, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Profile Input Sheet Card — Form Column 3 and Closing Window Tags 
                        This final XAML block lays out the third form segment containing school history, 
                        application review state fields, and 
                        the action panel containing your Save Changes, Approve, and Reject buttons.
                        -->
                        <!-- PROFILE COLUMN 3: Academic History & Control Pipeline Action Buttons -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Stretch">
                            <TextBlock Text="Previous School Name" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.PrevSchoolName, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. West High School"/>

                            <TextBlock Text="Cumulative Graduation GPA" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.Gpa, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="0.00 to 4.00"/>

                            <TextBlock Text="High School Graduation Year" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.GraduationYear, UpdateSourceTrigger=PropertyChanged}" h:WatermarkService.Watermark="e.g. 2024"/>

                            <TextBlock Text="Application Profile Status" FontWeight="Medium" Margin="0,0,0,4" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedStudent.ApplicationStatus}" IsReadOnly="True" Background="#F3F4F6"/>

                            <!-- Master Operations Action Pipeline Button Sets -->
                            <Button Content="💾 Apply General Value Updates" Command="{Binding SaveStudentChangesCommand}" Background="#4B5563" Foreground="White" Padding="10,6" BorderThickness="0" Margin="0,5,0,15" FontWeight="Medium"/>

                            <UniformGrid Columns="2">
                                <Button Content="Reject File" Command="{Binding RejectCommand}" Background="#EF4444" Foreground="White" Padding="10,6" BorderThickness="0" Margin="0,0,5,0" FontWeight="Medium"/>
                                <Button Content="Approve Entry" Command="{Binding ApproveCommand}" Background="#10B981" Foreground="White" Padding="10,6" BorderThickness="0" FontWeight="Medium"/>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid> <!-- Closes Inner Row/Column Main Control Panel Workspace Grid -->
        </ScrollViewer> <!-- Closes Outer ScrollViewer Box Framework Layer -->
    </Grid> <!-- Closes Outer Root Window Main Workspace Master Application Grid Frame -->
</Window>
